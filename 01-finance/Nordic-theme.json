{
  "name": "Nordic-Finesse",

  "background": "#F4F7F9",
  "backgroundLight": "#FFFFFF",
  "backgroundNeutral": "#EAF1F4",

  "foreground": "#1F2A33",
  "foregroundNeutralSecondary": "#6B7C86",
  "foregroundNeutralTertiary": "#8A9AA3",

  "tableAccent": "#3E6F83",

  "dataColors": [
    "#3E6F83",
    "#6C99A8",
    "#9FBBC6",
    "#C8DCE3",
    "#4C5C68",
    "#7E8E99",
    "#2F4858",
    "#B0BEC5"
  ],

  "visualStyles": {

    "page": {
      "*": {
        "outspace": [{
          "color": { "solid": { "color": "#EAF1F4" } }
        }],
        "background": [{
          "color": { "solid": { "color": "#F4F7F9" } },
          "transparency": 0
        }]
      }
    },

    "*": {
      "*": {
        "background": [{
          "color": { "solid": { "color": "#FFFFFF" } },
          "transparency": 0
        }],
        "border": [{
          "show": false
        }],
        "labelColor": {
          "solid": { "color": "#1F2A33" }
        }
      }
    },

    "barChart": {
      "*": {
        "legend": [{ "show": false }],
        "title": [{ "show": false }],
        "categoryAxis": [{
          "show": true,
          "showAxisTitle": false,
          "fontSize": 9,
          "labelColor": { "solid": { "color": "#6B7C86" } }
        }],
        "valueAxis": [{
          "show": false
        }],
        "labels": [{
          "show": false
        }]
      }
    },

    "clusteredColumnChart": {
      "*": {
        "legend": [{ "show": false }],
        "title": [{ "show": false }],
        "categoryAxis": [{
          "fontSize": 9,
          "labelColor": { "solid": { "color": "#6B7C86" } }
        }],
        "valueAxis": [{
          "show": false
        }],
        "labels": [{
          "show": false
        }]
      }
    },

    "lineChart": {
      "*": {
        "legend": [{ "show": false }],
        "title": [{ "show": false }],
        "categoryAxis": [{
          "fontSize": 9,
          "labelColor": { "solid": { "color": "#6B7C86" } }
        }],
        "valueAxis": [{
          "labelColor": { "solid": { "color": "#6B7C86" } }
        }],
        "labels": [{
          "show": false
        }]
      }
    },

    "card": {
      "*": {
        "categoryLabels": [{ "show": false }],
        "background": [{
          "color": { "solid": { "color": "#FFFFFF" } }
        }],
        "callout": [{
          "color": { "solid": { "color": "#1F2A33" } },
          "fontSize": 28
        }]
      }
    },

    "treemap": {
      "*": {
        "title": [{
          "show": true,
          "fontSize": 16,
          "fontColor": { "solid": { "color": "#1F2A33" } }
        }],
        "categoryLabels": [{
          "show": true,
          "fontSize": 11,
          "color": { "solid": { "color": "#FFFFFF" } }
        }],
        "legend": [{
          "show": false
        }]
      }
    },

    "tableEx": {
      "*": {
        "grid": [{
          "gridVertical": false,
          "gridHorizontal": false
        }],
        "columnHeaders": [{
          "backColor": { "solid": { "color": "#EAF1F4" } },
          "fontColor": { "solid": { "color": "#1F2A33" } },
          "outline": "None",
          "fontSize": 10
        }],
        "values": [{
          "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
          "backColorSecondary": { "solid": { "color": "#F4F7F9" } },
          "fontSize": 10,
          "fontColor": { "solid": { "color": "#4C5C68" } }
        }],
        "total": [{ "show": false }],
        "subTotals": [{
          "rowSubtotals": false,
          "columnSubtotals": false
        }]
      }
    },

    "donutChart": {
      "*": {
        "legend": [{ "show": false }],
        "title": [{ "show": false }],
        "labels": [{
          "show": false
        }]
      }
    }
  },

  "textClasses": {
    "label": {
      "color": "#6B7C86",
      "fontSize": 10
    },
    "callout": {
      "color": "#1F2A33",
      "fontSize": 28
    },
    "title": {
      "color": "#1F2A33",
      "fontSize": 18
    },
    "header": {
      "color": "#1F2A33",
      "fontSize": 14
    }
  }
}
